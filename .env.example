# Backtrack uses locally imported official NSE daily data for research backtests.
# No broker account, client ID, access token, paid subscription, or API key is required.

# Comma-separated origins allowed to call the API from browsers.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional local Ollama model for reviewable hypothesis suggestions.
# It is not required for historical backtesting.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b

# Local persistent cache for downloaded historical candles.
MARKET_CACHE_PATH=data/market_cache.sqlite3

# Optional frontend API override. Put this in frontend/.env.local when needed.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
